# ── How email codes get sent ──────────────────────────────
# console  = print the code to the server log / show on screen (no real email; great for testing)
# resend   = real email via Resend  (set RESEND_API_KEY + EMAIL_FROM)
# mandrill = real email via Mailchimp Transactional (set MANDRILL_API_KEY + EMAIL_FROM)
EMAIL_PROVIDER=console

# Sender identity for real email (Resend/Mandrill). Use a verified domain.
EMAIL_FROM=Room Tone <onboarding@resend.dev>

# Resend
RESEND_API_KEY=

# Mailchimp Transactional (Mandrill)
MANDRILL_API_KEY=

# ── Database ──────────────────────────────────────────────
# Leave DATABASE_URL UNSET to use a local SQLite file (local laptop mode).
# Set it to a Postgres connection string for deployed mode (Vercel/Neon/Supabase).
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSL=disable   # only if your Postgres does NOT use SSL

# Local SQLite file path (local mode only)
SQLITE_PATH=./roomtone.db

# Port (local mode)
PORT=3000

# ── Realtime (Ably) ───────────────────────────────────────
# Server-side root key from the Ably app (API Keys tab). Format: appId.keyId:secret.
# When set, clients subscribe for instant round/leaderboard updates; when unset,
# the app falls back to polling automatically. Never shipped to the browser.
ABLY_API_KEY=

# ── SMS (Twilio) — go-live text notifications ─────────────
# console (default) = log only, no real texts. twilio = real sends.
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Prefer a Messaging Service (A2P 10DLC); or set a single TWILIO_FROM number.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=
