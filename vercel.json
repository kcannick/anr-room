{
  "version": 2,
  "buildCommand": "bash scripts/vercel-build.sh",
  "functions": { "api/index.js": { "maxDuration": 30, "includeFiles": "assets/fonts/**" } },
  "crons": [
    { "path": "/api/cron/artist-sms", "schedule": "0 * * * *" }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
